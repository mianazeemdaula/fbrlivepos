generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
}

enum InvoiceStatus {
  DRAFT
  VALIDATED
  CONFIRMED
  PENDING
  QUEUED
  SUBMITTED
  FAILED
  CANCELLED
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum BillingStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  WAIVED
}

enum AnnouncementType {
  INFO
  WARNING
  MAINTENANCE
  FEATURE
}

// ─── PRAL DI ENUMS ───────────────────────────────────────────────────────────

enum DIEnvironment {
  SANDBOX
  PRODUCTION
}

enum IRISStatus {
  PENDING
  IP_SUBMITTED
  IP_APPROVED
  SANDBOX_ACCESS
  PRODUCTION_READY
}

enum IPStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum ScenarioStatus {
  PENDING
  SUBMITTED
  PASSED
  FAILED
}

// ─── PLATFORM LEVEL ──────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String   @unique
  phone     String?
  address   String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferredIdType String? // 'NTN' | 'CNIC' — default buyer ID type for invoices (NTN = first 7 digits)

  diCredentials    DICredentials?
  sandboxScenarios SandboxScenario[]
  subscription     TenantSubscription?
  users            User[]
  posTerminals     POSTerminal[]
  products         Product[]
  invoices         Invoice[]
  submissionLogs   FBRSubmissionLog[]
  featureFlags     TenantFeatureFlag[]
  customers        Customer[]
}

model POSTerminal {
  id         String    @id @default(cuid())
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  tenantId   String
  name       String
  location   String?
  isActive   Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  invoices   Invoice[]

  @@index([tenantId])
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  tenantId  String
  name      String
  email     String
  password  String
  role      UserRole  @default(CASHIER)
  pin       String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  invoices  Invoice[]

  @@unique([email, tenantId])
  @@index([tenantId])
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model Product {
  id                                String         @id @default(cuid())
  tenant                            Tenant         @relation(fields: [tenantId], references: [id])
  tenantId                          String
  name                              String
  sku                               String?
  hsCode                            String
  description                       String?
  price                             Decimal        @db.Decimal(10, 2)
  taxRate                           Decimal        @db.Decimal(5, 2)
  unit                              String
  // DI scenario classification
  diScenarioId                      String?        // e.g. "SN001" — which scenario this product uses
  diScenario                        DIScenario?    @relation(fields: [diScenarioId], references: [id])
  diSaleType                        String?
  diRate                            String?
  diUOM                             String?
  diFixedNotifiedValueOrRetailPrice Decimal?       @db.Decimal(10, 2)
  diSalesTaxWithheldAtSource        Decimal?       @db.Decimal(10, 2)
  extraTax                          Decimal?       @db.Decimal(10, 2)
  furtherTax                        Decimal?       @db.Decimal(10, 2)
  fedPayable                        Decimal?       @db.Decimal(10, 2)
  sroScheduleNo                     String?
  sroItemSerialNo                   String?
  isActive                          Boolean        @default(true)
  createdAt                         DateTime       @default(now())
  invoiceItems                      InvoiceItem[]
  hsCodeMapping                     ProductHSCode?

  @@index([tenantId])
  @@index([tenantId, hsCode])
}

// ─── INVOICES ─────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  tenantId        String
  terminal        POSTerminal?  @relation(fields: [terminalId], references: [id])
  terminalId      String?
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  customer        Customer?     @relation(fields: [customerId], references: [id])
  customerId      String?
  invoiceNumber   String
  invoiceDate     DateTime      @default(now())
  buyerNTN        String?
  buyerName       String?
  buyerPhone      String?
  subtotal        Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  status          InvoiceStatus @default(DRAFT)
  submissionError String?
  retryCount      Int           @default(0)
  queuedAt        DateTime?
  confirmedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           InvoiceItem[]

  // Invoice type: Sale Invoice or Debit Note
  invoiceType           String?   @default("Sale Invoice")
  // For Debit Notes — reference to original FBR invoice number
  invoiceRefNo          String?

  // PRAL DI specific fields
  buyerProvince         String?
  buyerAddress          String?
  buyerRegistrationType String? // "Registered" or "Unregistered"
  diScenarioId          String? // Sandbox scenario ID (e.g. "SN001") — required for SANDBOX submissions
  diReferenceInvoiceNo  String? // For Debit Notes — original FBR invoice number
  diInvoiceNumber       String? // FBR-issued invoice number (22 or 28 digits)
  diInvoiceDate         DateTime? // Date confirmed by FBR
  diStatusCode          String? // "00" = Valid, "01" = Invalid
  diStatus              String? // "Valid" or "Invalid"
  diItemStatuses        Json? // Array of per-item validation statuses
  diErrorCode           String? // Error code from FBR if invalid
  diErrorMessage        String? // Error message from FBR
  lastValidatedAt       DateTime? // When validateinvoicedata last ran
  lastValidationResult  Json? // Full validation response stored
  qrCodeData            String? // Data to encode in QR (version 2.0, 25×25, 1×1 inch)
  qrCodePrinted         Boolean   @default(false)

  submissionLogs FBRSubmissionLog[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  hsCode    String
  name      String
  quantity  Decimal @db.Decimal(10, 3)
  unit      String
  unitPrice Decimal @db.Decimal(10, 2)
  taxRate   Decimal @db.Decimal(5, 2)
  taxAmount Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  // PRAL DI specific fields
  diRate                            String? // Exact string from Reference API 5.8 ratE_DESC
  diUOM                             String? // Exact string from Reference API 5.6 description
  diSaleType                        String? // Exact string from Reference API
  diFixedNotifiedValueOrRetailPrice Decimal? @db.Decimal(10, 2)
  diSalesTaxWithheldAtSource        Decimal? @db.Decimal(10, 2)
  extraTax                          Decimal? @db.Decimal(10, 2)
  furtherTax                        Decimal? @db.Decimal(10, 2)
  fedPayable                        Decimal? @db.Decimal(10, 2)
  discount                          Decimal? @db.Decimal(10, 2)
  sroScheduleNo                     String?
  sroItemSerialNo                   String?
}

// ─── LOGS ─────────────────────────────────────────────────────────────────────

model FBRSubmissionLog {
  id           String   @id @default(cuid())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  tenantId     String
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id])
  attempt      Int
  requestBody  Json
  responseCode Int?
  responseBody Json?
  error        String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([invoiceId])
}

model InvoiceCounter {
  tenantId     String @id
  currentValue Int    @default(0)
}

// ─── SUBSCRIPTION PLANS ───────────────────────────────────────────────────────

model SubscriptionPlan {
  id                  String               @id @default(cuid())
  name                String               @unique
  slug                String               @unique
  description         String
  isActive            Boolean              @default(true)
  isPublic            Boolean              @default(true)
  sortOrder           Int                  @default(0)
  trialDays           Int                  @default(0)
  priceMonthly        Decimal              @db.Decimal(10, 2)
  priceYearly         Decimal              @db.Decimal(10, 2)
  currency            String               @default("PKR")
  maxPosTerminals     Int?
  maxUsers            Int?
  maxProducts         Int?
  maxInvoicesMonth    Int?
  maxHsCodesAccess    Int?
  dataRetentionDays   Int                  @default(365)
  features            PlanFeature[]
  tenantSubscriptions TenantSubscription[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model PlanFeature {
  id     String           @id @default(cuid())
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])
  planId String
  key    String
  value  String
  label  String

  @@unique([planId, key])
}

model TenantSubscription {
  id                   String           @id @default(cuid())
  tenant               Tenant           @relation(fields: [tenantId], references: [id])
  tenantId             String           @unique
  plan                 SubscriptionPlan @relation(fields: [planId], references: [id])
  planId               String
  status               SubStatus        @default(TRIALING)
  billingCycle         BillingCycle     @default(MONTHLY)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  cancelledAt          DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  billingHistory       BillingRecord[]
}

model BillingRecord {
  id                    String             @id @default(cuid())
  subscription          TenantSubscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId        String
  tenantId              String
  amount                Decimal            @db.Decimal(10, 2)
  currency              String             @default("PKR")
  status                BillingStatus      @default(PENDING)
  description           String
  periodStart           DateTime
  periodEnd             DateTime
  paidAt                DateTime?
  paymentMethod         String?
  paymentRef            String?
  stripeInvoiceId       String?
  stripePaymentIntentId String?
  invoicePdfUrl         String?
  createdAt             DateTime           @default(now())

  @@index([tenantId])
}

// ─── HS CODE MASTER LIBRARY ──────────────────────────────────────────────────

model HSCode {
  id              String          @id @default(cuid())
  code            String          @unique
  description     String
  shortName       String?
  category        String
  subCategory     String?
  unit            String          @default("PCS")
  defaultTaxRate  Decimal         @db.Decimal(5, 2)
  isFBRActive     Boolean         @default(true)
  notes           String?
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  productMappings ProductHSCode[]

  @@index([code])
  @@index([category])
}

model ProductHSCode {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String   @unique
  hsCode    HSCode   @relation(fields: [hsCodeId], references: [id])
  hsCodeId  String
  tenantId  String
  taxRate   Decimal  @db.Decimal(5, 2)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ─── FEATURE FLAGS ────────────────────────────────────────────────────────────

model FeatureFlag {
  id              String              @id @default(cuid())
  key             String              @unique
  description     String
  isGlobal        Boolean             @default(false)
  isActive        Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenantOverrides TenantFeatureFlag[]
}

model TenantFeatureFlag {
  id        String      @id @default(cuid())
  flag      FeatureFlag @relation(fields: [flagId], references: [id])
  flagId    String
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  enabled   Boolean
  createdAt DateTime    @default(now())

  @@unique([flagId, tenantId])
  @@index([tenantId])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  actorRole  String
  tenantId   String?
  action     String
  entity     String?
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ─── PLATFORM ANNOUNCEMENTS ──────────────────────────────────────────────────

model Announcement {
  id            String           @id @default(cuid())
  title         String
  body          String           @db.Text
  type          AnnouncementType @default(INFO)
  targetPlans   String[]
  startsAt      DateTime
  endsAt        DateTime?
  isDismissable Boolean          @default(true)
  createdAt     DateTime         @default(now())
}

// ─── PRAL DI CREDENTIALS ────────────────────────────────────────────────────

model DICredentials {
  id       String @id @default(cuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String @unique

  // Taxpayer identity (from their IRIS profile)
  sellerNTN          String // 7-digit NTN (e.g. "0786909")
  sellerCNIC         String? // 13-digit CNIC (alternative to NTN)
  sellerBusinessName String // Registered business name
  sellerProvince     String // Must match province codes from Reference API 5.1
  sellerAddress      String // Business address

  // PRAL-issued security token (per taxpayer, 5-year validity)
  // Stored encrypted with AES-256-GCM
  encryptedSandboxToken    String? // Token for sandbox testing
  encryptedProductionToken String? // Token for live submissions

  // Environment state
  environment       DIEnvironment @default(SANDBOX)
  isProductionReady Boolean       @default(false)

  // Registration status tracking
  irisRegistrationStatus  IRISStatus @default(PENDING)
  ipWhitelistStatus       IPStatus   @default(PENDING)
  sandboxCompleted        Boolean    @default(false)
  sandboxCompletedAt      DateTime?
  productionTokenIssuedAt DateTime?

  // Business classification (determines which sandbox scenarios to complete)
  businessActivity String // Manufacturer/Importer/Distributor/Wholesaler/Retailer/Service Provider/Exporter/Other
  sector           String // Steel/FMCG/Textile/Telecom/Petroleum/Electricity/Gas/Services/Automobile/CNG/Pharmaceuticals/Wholesale Retails/Other

  // Token validity
  tokenExpiresAt    DateTime? // 5 years from issuance
  lastVerifiedAt    DateTime?
  verificationError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Track sandbox scenario completion per tenant
model SandboxScenario {
  id          String         @id @default(cuid())
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  tenantId    String
  scenarioId  String // SN001, SN002, etc.
  description String
  status      ScenarioStatus @default(PENDING)
  completedAt DateTime?
  invoiceNo   String? // FBR-issued invoice number from successful test
  errorCode   String?
  errorDetail String?
  createdAt   DateTime       @default(now())

  @@unique([tenantId, scenarioId])
  @@index([tenantId])
}

// ─── PRAL REFERENCE DATA CACHE ──────────────────────────────────────────────

model DIProvince {
  code        Int    @id // stateProvinceCode
  description String // stateProvinceDesc (e.g. "PUNJAB", "SINDH")
}

model DIDocumentType {
  id          Int    @id // docTypeId
  description String // "Sale Invoice", "Debit Note"
}

model DIUnitOfMeasure {
  id          Int    @id // uoM_ID
  description String // "KG", "Numbers, pieces, units", etc.
}

model DIRate {
  id          Int     @id // ratE_ID
  description String // "18%", "0%", "18% along with rupees 60 per kilogram"
  value       Decimal @db.Decimal(5, 2) // numeric rate value
}

model DISaleType {
  code        String @id // internal code
  description String // "Goods at Standard Rate (default)", "Exempt Goods", etc.
}

// HS Code + valid UOM combinations (from API 5.9)
model DIHSCodeUOM {
  id         String @id @default(cuid())
  hsCode     String
  uomId      Int
  uomDesc    String
  annexureId Int    @default(3) // Sales annexure

  @@unique([hsCode, uomId, annexureId])
  @@index([hsCode])
}

// Transaction Types from PRAL Reference API 3.5
model DITransactionType {
  id          Int    @id // transactioN_TYPE_ID
  description String // transactioN_DESC (e.g. "DTRE goods")
}

// SRO Schedule from PRAL Reference API 3.7
model DISROSchedule {
  id          Int    @id // srO_ID
  description String // srO_DESC (e.g. "Zero Rated Gas")
}

// SRO Item Details from PRAL Reference API 3.10
model DISROItem {
  id          Int    @id // srO_ITEM_ID
  description String // srO_ITEM_DESC
}

// HS Code master from PRAL Reference API 3.3
model DIItemDescription {
  id          String @id @default(cuid())
  hsCode      String @unique // hS_CODE
  description String // description
}

// ─── DI SCENARIO CATALOGUE (from FBR documentation section 5 & 6) ───────────

// All 28 scenarios with their saleType strings — seeded from documentation
model DIScenario {
  id          String @id // "SN001", "SN002", etc.
  description String // Human-readable description
  saleType    String // Exact string to pass as saleType in invoice payload
  notes       String? // Additional rules/notes

  businessScenarios DIBusinessScenario[]
  products          Product[]

  @@map("di_scenarios")
}

// Business Activity + Sector → applicable scenarios matrix
model DIBusinessScenario {
  id               String    @id @default(cuid())
  businessActivity String    // "Manufacturer", "Retailer", etc.
  sector           String    // "Steel", "FMCG", etc.
  scenarioId       String
  scenario         DIScenario @relation(fields: [scenarioId], references: [id])

  @@unique([businessActivity, sector, scenarioId])
  @@map("di_business_scenarios")
}

// ─── CUSTOMERS (BUYERS) ─────────────────────────────────────────────────────

model Customer {
  id                  String    @id @default(cuid())
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  tenantId            String
  name                String
  ntnCnic             String? // 7-digit NTN or 13-digit CNIC
  phone               String?
  email               String?
  province            String?
  address             String?
  registrationType    String? // "Registered" or "Unregistered" — from FBR verification
  atlStatus           String? // "Active" or "In-Active" — from FBR ATL check
  fbrVerified         Boolean   @default(false)
  fbrVerifiedAt       DateTime?
  fbrRegistrationNo   String? // REGISTRATION_NO from FBR response
  fbrRegistrationType String? // REGISTRATION_TYPE from FBR response
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  invoices            Invoice[]

  @@unique([tenantId, ntnCnic])
  @@index([tenantId])
  @@index([tenantId, name])
}
